# Servizio TTS compatibile con OpenAI Audio Speech API
TTS_API_URL=https://api.openai.com/v1/audio/speech
TTS_API_KEY=inserisci_qui_la_tua_api_key
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_SPEED=0.95
TTS_OUTPUT_FORMAT=mp3

# Output video
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=25
VIDEO_CRF=20
VIDEO_PRESET=medium
